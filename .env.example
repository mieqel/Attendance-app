# Neon connection strings — get these from your Neon project dashboard.
# DATABASE_URL should be the "pooled" connection string.
# DIRECT_URL should be the "direct" (unpooled) connection string — Prisma needs
# this for migrations even though the app uses the pooled one at runtime.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# The 4-digit pincode you'll enter on /admin/login. Change this to whatever
# you like — it's just a plain number, no letters.
ADMIN_PIN="2716"

# Random secret used to sign the admin session cookie.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-too"
